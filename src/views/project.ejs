<%- include('partials/header') %>

<main>
    <h1><%= project.title %></h1>
    <p class="project-date">
        <%= project.project_date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' }) %>
    </p>
    <p class="project-location"><%= project.location %></p>
    <p><%= project.description %></p>
    <p>
        Sponsored by
        <a href="/organization/<%= project.organization_id %>"><%= project.organization_name %></a>
    </p>

    <% if (categories.length > 0) { %>
        <ul class="category-tags">
            <% categories.forEach(category => { %>
                <li><a href="/category/<%= category.category_id %>"><%= category.name %></a></li>
            <% }); %>
        </ul>
    <% } %>

    <p><a href="/projects">&larr; Back to all projects</a></p>
</main>

<%- include('partials/footer') %>
